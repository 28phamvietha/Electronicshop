                #toast-box {
                    position: fixed;
                    top: 100px;
                    right: 20px;
                    z-index: 99999999;
                }

                .toast {
                    background: #333;
                    color: #fff;
                    padding: 12px 16px;
                    margin-bottom: 10px;
                    border-radius: 5px;
                    opacity: 0;
                    transform: translateX(100%);
                    transition: all 0.4s ease;
                    display: block !important;
                }

                    .toast.show {
                        opacity: 1;
                        transform: translateX(0);
                    }

                    .toast.success {
                        background: #28a745;
                    }

                    .toast.error {
                        background: #dc3545;
                    }

