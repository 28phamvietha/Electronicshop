    <button id="chatToggle" class="chat-bubble" title="Trợ lý AI">
        <img src="/wwwroot/img/logo.png" />
    </button>

    <div id="chatPopup" class="chat-popup" aria-hidden="true" role="dialog" aria-label="Trợ lý AI">
        <div class="chat-header">
            <div style="display:flex;align-items:center;gap:8px;">
                <img src="/wwwroot/img/logo.png"
                     style="width:36px;height:36px;border-radius:50%;">
                <span>Electronics Shop</span>
            </div>
            <button class="close-btn" id="chatClose">&times;</button>
        </div>
        <div id="chatContent" class="chat-content" role="log" aria-live="polite"></div>
        <div class="chat-input">
            <textarea id="chatMessage" rows="1" placeholder="Gõ câu hỏi..."></textarea>
            <button id="chatSend" type="button">Gửi</button>
        </div>
    </div>



    <!-- jQuery Plugins -->
    <script src="~/wwwroot/js/jquery.min.js"></script>
    <script src="~/wwwroot/js/bootstrap.min.js"></script>
    <script src="~/wwwroot/js/slick.min.js"></script>
