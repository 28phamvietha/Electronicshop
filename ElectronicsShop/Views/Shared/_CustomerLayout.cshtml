            display: flex;
        }

        /* ===== BOX MỖI CỘT ===== */
        .footer {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            width: 100%;
            gap: 12px;
        }

        /* ===== TITLE ===== */
        .footer .footer-title {
            color: #fff;
            text-transform: uppercase;
            font-size: 15px;
            font-weight: 600;
            letter-spacing: 0.5px;
            position: relative;
            padding-bottom: 10px;
            min-height: 50px; /* 👈 giúp title thẳng hàng */
            display: flex;
            align-items: flex-end;
        }

        .footer .footer-title::after {
            content: "";
            width: 30px;
            height: 2px;
            background: #3b82f6;
            position: absolute;
            left: 0;
            bottom: 0;
            border-radius: 2px;
        }

        /* ===== TEXT CỘT 1 ===== */
        .footer p {
            font-size: 14px;
            line-height: 1.6;
            max-width: 95%;
        }

        /* 👉 nếu muốn đều tuyệt đối thì bật cái này */
        .footer p {
            display: -webkit-box;
            -webkit-line-clamp: 4; /* giới hạn 4 dòng */
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* ===== LIST ===== */
        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-links li {
            margin-bottom: 10px;
        }

        /* ===== LINK ===== */
        .footer-links li a {
            color: #9ca3af;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .footer-links li a:hover {
            color: #fff;
            transform: translateX(4px);
        }

        /* ===== ICON ===== */
        .footer-links li i {
            margin-right: 10px;
            color: #ef4444;
            font-size: 13px;
        }

