<body>
    @* Prepare dynamic cart + wishlist data for header *@
    @{
        var cartItems = new List<ElectronicsShop.Models.Cart>();
        int cartCount = 0;
        decimal cartSubtotal = 0M;

        var wishlistItems = new List<ElectronicsShop.Models.Wishlist>();
        int wishlistCount = 0;

        if (Session["UserId"] != null)
        {
            try
            {
                int userId = (int)Session["UserId"];
                // Cart items
                cartItems = new ElectronicsShop.Controllers.CartController().GetCartItemsByUserId(userId) ?? new List<ElectronicsShop.Models.Cart>();
                cartCount = cartItems.Sum(ci => (ci.quantity ?? 0));
                foreach (var ci in cartItems)
                {
                    var price = ci.Product?.discount_price ?? ci.Product?.price ?? 0M;
                    cartSubtotal += (ci.quantity ?? 0) * price;
                }

                // Wishlist items (HomeController contains GetWishListItemsByUserId)
                wishlistItems = new ElectronicsShop.Controllers.WishlistController().GetWishListItemsByUserId(userId) ?? new List<ElectronicsShop.Models.Wishlist>();
                wishlistCount = wishlistItems.Count;
            }
            catch
            {
                // Fail silently to avoid breaking rendering in layout
                cartItems = new List<ElectronicsShop.Models.Cart>();
                cartCount = 0;
                cartSubtotal = 0M;
                wishlistItems = new List<ElectronicsShop.Models.Wishlist>();
                wishlistCount = 0;
            }
        }
    }

