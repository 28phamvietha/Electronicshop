                /* Chat widget styles */
                /* ===== NÚT CHAT ===== */
        .chat-bubble {
            position: fixed;
            right: 22px;
            bottom: 22px;
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: #15161D;
            border: 2px solid #D10024;
            box-shadow: 0 6px 18px rgba(0,0,0,0.25);
            cursor: pointer;
            z-index: 1200;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 5px;
            transition: 0.2s;
        }
        .chat-bubble:hover {
            transform: scale(1.1);
        }
        .chat-bubble img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        /* ===== POPUP ===== */
        .chat-popup {
            position: fixed;
            right: 22px;
            bottom: 90px;
            width: 360px;
            height: 460px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            z-index: 1199;
            display: none;
            flex-direction: column;
            overflow: hidden;
        }
        .chat-popup.open {
            display: flex;
        }

        /* ===== HEADER ===== */
        .chat-header {
            padding: 10px 14px;
            background: #15161D;
            color: #fff;
            font-weight: 600;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #D10024;
        }
        .chat-header img {
            border-radius: 50%;
            border: 2px solid #D10024;
        }
        .chat-header .close-btn {
            background: none;
            border: none;
            color: #fff;
            font-size: 18px;
            cursor: pointer;
        }

        /* ===== CONTENT ===== */
        .chat-content {
            padding: 12px;
            background: #f7fafc;
            overflow-y: auto;
            flex: 1;
        }

        /* ===== MESSAGE ===== */
        .chat-message {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            margin-bottom: 6px;
        }
            .chat-message .meta {
                display: none;
            }

        /* avatar */
        .chat-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #15161D;
            padding: 2px;
            border: 2px solid #D10024;
            object-fit: cover;
        }

        /* nội dung */
        .chat-bubble-wrap {
            display: flex;
            flex-direction: column;
            max-width: 80%;
        }

        /* text chung */
        .chat-message .text {
            background: #fff;
            padding: 10px 14px;
            border-radius: 16px;
            display: inline-block;
            max-width: 100%; /* ❌ bỏ 75% */
            font-style: normal;
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            font-style: normal;
            transform: none;
            letter-spacing: normal;
            word-spacing: normal;
            white-space: pre-wrap;
            word-break: keep-all; /* ⬅️ KHÔNG cho bẻ chữ */
            overflow-wrap: break-word;
            line-height: 1.4;
        }

        /* ===== BOT ===== */
        .chat-message.assistant {
            justify-content: flex-start;
        }
        .chat-message.assistant .text {
            background: #fff;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        }

        /* 2 tin liên tiếp */
        .chat-message.assistant:first-of-type .chat-avatar {
            visibility: hidden;
        }
        .chat-message.assistant + .chat-message.assistant {
            margin-top: 2px;
        }

        /* bo góc giống messenger */
        .chat-message.assistant:first-of-type .text {
            border-radius: 16px 16px 6px 16px;
        }
        .chat-message.assistant + .chat-message.assistant .text {
            border-radius: 16px 16px 16px 6px;
        }

        /* ===== USER ===== */
        .chat-message.user {
            justify-content: flex-end;
        }
            .chat-message.user .chat-bubble-wrap {
                align-items: flex-end;
            }
            .chat-message.user .text {
                background: #D10024;
                color: #fff;
                
            }
        .chat-message.user .chat-avatar {
            display: none;
        }

        /* ===== INPUT (QUAN TRỌNG) ===== */
        .chat-input {
            padding: 10px;
            display: flex;
            gap: 8px;
            border-top: 1px solid #eee;
            align-items: flex-end;
        }

        /* textarea giống messenger */
            .chat-input textarea {
                flex: 1;
                min-height: 36px;
                max-height: 110px;
                padding: 8px 10px;
                border: 1px solid #e6edf3;
                border-radius: 12px;
                outline: none;
                font-size: 14px;
                line-height: 1.4;
                resize: none !important; /* ❌ tắt kéo */
                overflow-y: auto; /* chỉ scroll khi >5 dòng */

                -webkit-appearance: none; /* 🔥 fix Chrome/Edge */
                -moz-appearance: none;
                scrollbar-width: none; /* Firefox */
            }

                .chat-input textarea::-webkit-scrollbar {
                    display: none; /* Chrome */
                }
        .chat-input textarea:focus {
            border-color: #D10024;
        }

        /* nút gửi */
        .chat-input button {
            height: 38px;
            padding: 0 14px;
            border-radius: 50px;
            background: #D10024;
            color: #fff;
            border: none;
            cursor: pointer;
        }

        /* loading */
        .chat-loading {
            font-style: italic;
            color: #888;
        }

        /* responsive */
        @@media (max-width: 480px) {
            .chat-popup {
                width: 320px;
                height: 420px;
                right: 12px;
                bottom: 78px;
            }
            .chat-bubble {
                right: 12px;
                bottom: 12px;
            }
