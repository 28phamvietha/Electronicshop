    <script src="@Url.Content("~/wwwroot/js/wishlist.js")"></script>
    <script src="@Url.Content("~/wwwroot/js/cart.js")"></script>
    <div style="display:none">
        @Html.AntiForgeryToken()
    </div>
    <script>
        window.wishlistAddUrl = '@Url.Action("Add", "Wishlist")';
        window.wishlistLoginUrl = '@Url.Action("Login", "Account")';
        window.cartAddUrl = '@Url.Action("Add", "Cart")';
        window.cartRemoveUrl = '@Url.Action("Remove", "Cart")';
        window.cartLoginUrl = '@Url.Action("Login", "Account")';
    </script>

    <script>
        (function () {
            // Elements
            var toggle = document.getElementById('chatToggle');
            var popup = document.getElementById('chatPopup');
            var closeBtn = document.getElementById('chatClose');
            var sendBtn = document.getElementById('chatSend');
            var input = document.getElementById('chatMessage');
            input.addEventListener("input", function () {
                this.style.height = "auto";
                this.style.height = this.scrollHeight + "px";

                if (this.scrollHeight > 120) {
                    this.style.height = "120px"; // max ~5 dòng
                }
            });
            var content = document.getElementById('chatContent');

            var chatUrl = '@Url.Action("Send", "Chat")';
            // get anti-forgery token value if present
            var afElem = document.querySelector('input[name="__RequestVerificationToken"]');
            var afToken = afElem ? afElem.value : null;

            let hasWelcomed = false;
            function openPopup() {
                popup.classList.add('open');
                popup.setAttribute('aria-hidden', 'false');
                input.focus();
                if (!hasWelcomed) {
                    appendMessage(
                        'Trợ lý',
                        'Xin chào Anh/Chị! Em là trợ lý AI của ElectronicsShop 😊',
                        'assistant'
                    );

                    // giả lập đang nhập
                    let typing = appendLoading();

                    setTimeout(() => {
                        content.removeChild(typing);

                        appendMessage(
                            'Trợ lý',
                            'Em rất sẵn lòng hỗ trợ Anh/Chị! 😊',
                            'assistant'
                        );
                    }, 1000);

                    hasWelcomed = true;
                }
            }
            function closePopup() {
                popup.classList.remove('open');
                popup.setAttribute('aria-hidden', 'true');
                toggle.focus();
            }

            function appendMessage(who, text, cssClass) {
                var wrap = document.createElement('div');
                wrap.className = 'chat-message ' + (cssClass || '');

                // avatar (chỉ bot mới có)
                var avatar = document.createElement('img');
                avatar.className = 'chat-avatar';
                avatar.src = '/wwwroot/img/logo.png'; // 👉 đường dẫn logo của bạn   ~/wwwroot/img/logo.png

                var contentWrap = document.createElement('div');
                contentWrap.className = 'chat-bubble-wrap';

                var meta = document.createElement('div');
                meta.className = 'meta';
                if (cssClass === 'assistant') {
                    meta.style.display = 'none'; // ẩn "Trợ lý"
                } else {
                    meta.textContent = who;
                }

                var txt = document.createElement('div');
                txt.className = 'text';
                txt.textContent = text;

                // nếu là bot → có avatar
                if (cssClass === 'assistant') {
                    wrap.appendChild(avatar);
                }

                contentWrap.appendChild(meta);
                contentWrap.appendChild(txt);
                wrap.appendChild(contentWrap);

                content.appendChild(wrap);
                content.scrollTop = content.scrollHeight;
            }

            function appendLoading() {
                var l = document.createElement('div');
                l.className = 'chat-message loading';
                l.innerHTML = '<div class="chat-loading">Đang xử lý...</div>';
                content.appendChild(l);
                content.scrollTop = content.scrollHeight;
                return l;
            }

            async function sendMessage() {
                var msg = input.value.trim();
                if (!msg) return;
                appendMessage('Bạn', msg, 'user');
                input.value = '';
                input.style.height = "auto"; // reset lại chiều cao
                var loading = appendLoading();

                try {
                    var form = new FormData();
                    form.append('message', msg);
                    if (afToken) form.append('__RequestVerificationToken', afToken);

                    var res = await fetch(chatUrl, {
                        method: 'POST',
                        body: form,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    var text = await res.text();

                    try {
                        var j = JSON.parse(text);
                    } catch (e) {
                        console.error("Server trả về:", text);
                        appendMessage('Lỗi', 'Server lỗi rồi 😅', 'error');
                        return;
                    }
                    content.removeChild(loading);

                    if (j.ok) {
                        appendMessage('Trợ lý', j.reply, 'assistant');
                    } else {
                        appendMessage('Hệ thống', j.error || 'Lỗi khi gọi trợ lý', 'error');
                    }
                } catch (e) {
                    if (content.contains(loading)) content.removeChild(loading);
                    appendMessage('Hệ thống', e.message || 'Lỗi kết nối', 'error');
                }
            }

            // events
            toggle.addEventListener('click', function () {
                if (popup.classList.contains('open')) closePopup(); else openPopup();
            });
            closeBtn.addEventListener('click', closePopup);
            sendBtn.addEventListener('click', sendMessage);
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // close when clicked outside (optional)
            document.addEventListener('click', function (e) {
                if (!popup.contains(e.target) && !toggle.contains(e.target) && popup.classList.contains('open')) {
                    closePopup();
                }
            });
        })();
    </script>

    <script>
        const searchBox = document.getElementById("searchBox");
        const suggestBox = document.getElementById("searchSuggest");

        if (searchBox && suggestBox) {

            // focus → hiện
            searchBox.addEventListener("focus", () => {
                suggestBox.style.display = "block";
            });

            // click ngoài → ẩn
            document.addEventListener("click", function (e) {
                if (!searchBox.contains(e.target) && !suggestBox.contains(e.target)) {
                    suggestBox.style.display = "none";
                }
            });

            // click keyword
            document.querySelectorAll(".suggest-item").forEach(item => {
                item.addEventListener("click", function () {
                    searchBox.value = this.innerText;

                    // auto search luôn
                    window.location.href = "/Product/Search?query=" + encodeURIComponent(this.innerText);
                });
            });
        }
    </script>

    <script>
        const texts = [
            "Bạn muốn tìm gì...",
            "iPhone 17 Series",
            "iPhone 16 Series",
            "iPhone 15 Series",
            "Laptop Gaming",
            "Samsung Galaxy",
            "Tai nghe Bluetooth",
            "Máy ảnh Canon"
        ];

        let i = 0;
        let j = 0;
        let currentText = "";
        let isDeleting = false;

        const input = document.getElementById("searchBox");

        function typeEffect() {
            currentText = texts[i];

            if (isDeleting) {
                input.placeholder = currentText.substring(0, j--);
            } else {
                input.placeholder = currentText.substring(0, j++);
            }

            if (!isDeleting && j === currentText.length) {
                isDeleting = true;
                setTimeout(typeEffect, 1000);
                return;
            }

            if (isDeleting && j === 0) {
                isDeleting = false;
                i = (i + 1) % texts.length;
            }

            setTimeout(typeEffect, isDeleting ? 50 : 100);
        }

        typeEffect();
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const btn = document.getElementById("menuToggle");
            const menu = document.getElementById("categoryMenu");

            // click mở
            btn.addEventListener("click", function (e) {
                e.stopPropagation();
                menu.classList.toggle("open");
            });

            // click ngoài → đóng
            document.addEventListener("click", function (e) {
                if (!menu.contains(e.target) && !btn.contains(e.target)) {
                    menu.classList.remove("open");
                }
            });

        });

    </script>


    <script>
        $(document).on("click", ".wishlist-add", function () {
            var btn = $(this);
            var productId = btn.data("productid");

            $.post("/Wishlist/Add", { productId: productId }, function (res) {
                if (res.success) {
                    var icon = btn.find("i");

                    if (res.already) {
                        icon.removeClass("text-danger");
                    } else {
                        icon.addClass("text-danger");
                    }
                } else if (res.redirectUrl) {
                    window.location.href = res.redirectUrl;
                }
            });
        });
    </script>

    <script>
        function addToCart(productId, quantity = 1) {
            $.ajax({
                url: window.cartAddUrl,
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function (res) {

                    if (res.redirectUrl) {
                        window.location.href = res.redirectUrl;
                        return;
                    }

                    if (res.success) {
                        showToast(res.message, "success");
                    } else {
                        showToast(res.message, "error");
                    }
                }
            });
        }
    </script>

    <script>
        function showToast(message, type = "success") {
            var toast = document.createElement("div");
            toast.className = "toast " + type;
            toast.innerText = message;

            var box = document.getElementById("toast-box");
            if (!box) {
                console.error("Không tìm thấy #toast-box");
                return;
            }

            box.appendChild(toast);

            setTimeout(() => {
                toast.classList.add("show");
            }, 10);

            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
    </script>

    @if (TempData["Success"] != null)
    {
        <script>
        document.addEventListener("DOMContentLoaded", function () {
            showToast(@Html.Raw(Json.Encode(TempData["Success"])), "success");
        });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
        document.addEventListener("DOMContentLoaded", function () {
            showToast(@Html.Raw(Json.Encode(TempData["Error"])), "error");
        });
        </script>
    }

