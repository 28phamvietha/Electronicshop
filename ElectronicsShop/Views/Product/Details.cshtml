@using System.Globalization
@using ElectronicsShop.Models
@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

@model ElectronicsShop.Models.Product
@{
    ViewBag.Title = "Xem chi tiết sản phẩm";
}

@{ var imageList = Model.Product_Images?.ToList() ?? new List<ElectronicsShop.Models.Product_Images>();
    var culture = new CultureInfo("vi-VN");
}

@{
    var wishlistIds = ViewBag.WishlistIds as List<int> ?? new List<int>();
    bool isFav = wishlistIds.Contains(Model.product_id);
}





<!-- SECTION -->
<div class="section">
    <!-- container -->
    <div class="container">
        <!-- row -->
        <div class="row">
            <!-- Product main img -->
            <div class="col-md-5 col-md-push-2">
                <div id="product-main-img">
                    @if (imageList.Any())
                    {
                        foreach (var img in imageList)
                        {
                            <div class="product-preview">
                                <img src="@Url.Content("~/Images/" + img.image_url)" alt="">
                            </div>
                        }
                    }
                    else
                    {
                        <div class="product-preview">
                            <img src="~/Images/noimage.png" alt="">
                        </div>
                    }

                </div>
            </div>
            <!-- /Product main img -->
            <!-- Product thumb imgs -->
            <div class="col-md-2  col-md-pull-5">
                <div id="product-imgs">
                    @foreach (var img in imageList)
                    {
                        <div class="product-preview">
                            <img src="@Url.Content("~/Images/" + img.image_url)" alt="">
                        </div>
                    }

                </div>
            </div>
            <!-- /Product thumb imgs -->
            <!-- Product details -->
            <div class="col-md-5">
                <div class="product-details">
                    <h2 class="product-name">@Model.product_name</h2>
                    <div>
                        <div class="product-rating">
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star"></i>
                            <i class="fa fa-star-o"></i>
                        </div>
                        @*<a class="review-link" href="#">10 Review(s) | Add your review</a>*@
                    </div>
                    <div>
                        <h3 class="product-price">
                            @((Model.discount_price ?? 0).ToString("C0", culture))
                            <del class="product-old-price">
                                @((Model.price ?? 0).ToString("C0", culture))
                            </del>
                        </h3>
                        <span class="product-available">Còn: @(Model.stock ?? 0)</span>

                    </div>
                    <p>
                        @Model.description
                    </p>


                    @using (Html.BeginForm("AddToCart", "Cart", FormMethod.Post))
                    {
                        <div class="add-to-cart">
                            <div class="qty-label">
                                Số lượng:
                                <div class="input-number">
                                    <input type="hidden" name="productId" value="@Model.product_id" />
                                    <input type="number" name="quantity" value="1" min="1" max="@Model.stock" />
                                    <span class="qty-up">+</span>
                                    <span class="qty-down">-</span>
                                </div>
                            </div>

                            <button type="button" class="add-to-cart-btn"><i class="fa fa-shopping-cart"></i> Thêm vào giỏ hàng</button>
                        </div>
                    }



                    <ul class="product-btns">
                        <li>
                            <a href="javascript:void(0)"
                               class="wishlist-add"
                               data-productid="@Model.product_id">

                                <i class="fa fa-heart @(isFav ? "text-danger" : "")"></i>
                                Thêm vào yêu thích
                            </a>
                        </li>
                        @*<li><a href="#"><i class="fa fa-exchange"></i> add to compare</a></li>*@
                    </ul>

                    <ul class="product-links">
                        <li>Danh mục:</li>
                        <li>
                            <a href="@Url.Action("ProductsByCategory", "Product", new { categoryId = @Model.Category.category_id })">@(Model.Category?.category_name ?? "")</a>
                        </li>
                    </ul>

                    <ul class="product-links">
                        <li>Chia sẻ:</li>
                        <li><a href="#"><i class="fa fa-facebook"></i></a></li>
                        <li><a href="#"><i class="fa fa-twitter"></i></a></li>
                        <li><a href="#"><i class="fa fa-google-plus"></i></a></li>
                        <li><a href="#"><i class="fa fa-envelope"></i></a></li>
                    </ul>

                </div>
            </div>
            <!-- /Product details -->
            <!-- Product tab -->
            <div class="col-md-12">
                <div id="product-tab">
                    <!-- product tab nav -->
                    <ul class="tab-nav">
                        <li class="active"><a data-toggle="tab" href="#tab1">Mô tả</a></li>
                        <li><a data-toggle="tab" href="#tab2">Chi tiết</a></li>
                        @*<li><a data-toggle="tab" href="#tab3">Reviews (3)</a></li>*@
                    </ul>
                    <!-- /product tab nav -->
                    <!-- product tab content -->
                    <div class="tab-content">
                        <!-- tab1  -->
                        <div id="tab1" class="tab-pane fade in active">
                            <div class="row">
                                <div class="col-md-12">
                                    <p>
                                        @Model.description
                                    </p>
                                </div>
                            </div>
                        </div>
                        <!-- /tab1  -->
                        <!-- tab2  -->
                        <div id="tab2" class="tab-pane fade in">
                            <div class="row">
                                <div class="col-md-12">

                                    <div class="spec-container">
                                        <h3 class="spec-title">Thông số kỹ thuật</h3>

                                        @{
                                            var groups = Model.Specifications?.GroupBy(x => x.spec_group);
                                        }

                                        @if (groups != null && groups.Any())
                                        {
                                            foreach (var group in groups)
                                            {
                                                <div class="spec-group">
                                                    <h4>@group.Key</h4>

                                                    <table class="spec-table">
                                                        @foreach (var item in group)
                                                        {
                                                            <tr>
                                                                <td class="spec-name">@item.spec_name</td>
                                                                <td class="spec-value">@item.spec_value</td>
                                                            </tr>
                                                        }
                                                    </table>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p>Chưa có thông số</p>
                                        }

                                    </div>

                                </div>
                            </div>
                        </div>
                        <!-- /tab2  -->
                        <!-- /product tab content  -->
                    </div>
                </div>
                <!-- /product tab -->
            </div>
            <!-- /row -->
        </div>
        <!-- /container -->
    </div>
    <!-- /SECTION -->
    <!-- REVIEW SECTION -->
    <div class="section">
        <div class="container">

            <h3>⭐ Đánh giá sản phẩm</h3>

            <!-- SUMMARY -->
            @if (ViewBag.RatingSummary != null)
            {
                var s = ViewBag.RatingSummary;

                <div class="row mb-4" style="background:#fff;padding:15px;border-radius:8px;">
                    <div class="col-md-3 text-center">
                      <h2 style="color:#ee4d2d">
                          @Math.Round(s.avg, 1)/5
                      </h2>
                        <p>@s.total đánh giá</p>
                    </div>

                    <div class="col-md-9">
                        @for (int i = 5; i >= 1; i--)
                        {
                            int count = (int)s.GetType().GetProperty("star" + i).GetValue(s);
                            int percent = s.total > 0 ? (count * 100 / s.total) : 0;

                            <div style="display:flex;align-items:center;margin-bottom:5px;">
                                <span style="width:50px">@i ⭐</span>

                                <div style="flex:1;background:#eee;height:8px;margin:0 10px;border-radius:5px;">
                                    <div style="@($"width:{percent}%; background:#ee4d2d; height:100%; border-radius:5px;")"></div>
                                </div>

                                <span>@count</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- FORM -->
            <div class="review-form" style="background:#fff;padding:15px;border-radius:8px;margin-bottom:20px;">
                <h4>✍️ Viết đánh giá</h4>

                <form method="post" action="@Url.Action("AddReview","Product")">
                    <input type="hidden" name="productId" value="@Model.product_id" />

                    <div class="form-group">
                        <label>Chọn số sao</label>
                        <select name="rating" class="form-control">
                            <option value="5">⭐⭐⭐⭐⭐</option>
                            <option value="4">⭐⭐⭐⭐</option>
                            <option value="3">⭐⭐⭐</option>
                            <option value="2">⭐⭐</option>
                            <option value="1">⭐</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Bình luận</label>
                        <textarea name="comment" class="form-control" rows="3"></textarea>
                    </div>

                    <button class="btn btn-danger">Gửi đánh giá</button>
                </form>
            </div>

            <!-- LIST REVIEW -->
            <div class="review-list">

                <h4>📝 Đánh giá từ khách hàng</h4>

                @if (ViewBag.Reviews != null && ((List<Review>)ViewBag.Reviews).Any())
                {
                    foreach (var r in (List<Review>)ViewBag.Reviews)
                    {
                        <div style="background:#fff;padding:15px;margin-bottom:10px;border-radius:8px;">

                            <b>@r.User.first_name @r.User.last_name</b>

                            <div>
                                @for (int i = 0; i < r.rating; i++)
                                {
                                    <span style="color:#f5b50a;">★</span>
                                }
                            </div>

                            <p>@r.comment</p>

                            <small style="color:gray">
                                @r.created_at.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    }
                }
                else
                {
                    <p>Chưa có đánh giá nào 😢</p>
                }

            </div>

        </div>
    </div>
    <!-- Section -->
    <div class="section">
        <!-- container -->
        <div class="container">
            <!-- row -->
            <div class="row">

                <div class="col-md-12">
                    <div class="section-title text-center">
                        <h3 class="title">Sản phẩm liên quan</h3>
                    </div>
                </div>

                <!-- product -->
                @{
                    var related = ViewBag.RelatedProducts as IEnumerable<ElectronicsShop.Models.Product>;
                }

                @if (related != null && related.Any())
                {
                    foreach (var product in related)
                    {
                        <div class="col-md-3 col-xs-6">
                            @Html.Partial("_Product", product)
                        </div>
                    }
                }
                <!-- /product -->



            </div>
            <!-- /row -->
        </div>
        <!-- /container -->
    </div>
    <!-- /Section -->
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const qtyInput = document.querySelector('input[name="quantity"]');

        qtyInput.addEventListener("input", function () {
            let val = this.value;

            // Cho phép xóa (rỗng) để nhập lại
            if (val === "") return;

            // Nếu nhỏ hơn 1 → tự set = 1
            if (parseInt(val) < 1) {
                this.value = 1;
            }
        });

        // Khi blur (rời khỏi ô) mà vẫn rỗng → set = 1
        qtyInput.addEventListener("blur", function () {
            if (this.value === "" || parseInt(this.value) < 1) {
                this.value = 1;
            }
        });
    });
</script>